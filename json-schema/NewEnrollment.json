{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NewEnrollment",
  "required": [
    "courseIds",
    "learnerIds",
    "dueDateType"
  ],
  "properties": {
    "courseIds": {
      "$ref": "#/components/schemas/ArrayOfIds"
    },
    "learnerIds": {
      "$ref": "#/components/schemas/ArrayOfIds"
    },
    "dueDateType": {
      "$ref": "#/components/schemas/DueDateType"
    },
    "dueDate": {
      "type": "string",
      "format": "date"
    },
    "duePeriod": {
      "type": "integer"
    },
    "accessDate": {
      "type": "string",
      "format": "date"
    },
    "lockAfterDueDate": {
      "type": "boolean"
    }
  },
  "type": "object",
  "xml": {
    "name": "request"
  }
}
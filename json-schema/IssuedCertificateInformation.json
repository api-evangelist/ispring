{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IssuedCertificateInformation",
  "required": [
    "issuedCertificateId",
    "issueDate"
  ],
  "properties": {
    "issuedCertificateId": {
      "type": "string",
      "format": "uuid"
    },
    "issueDate": {
      "type": "string",
      "format": "date"
    },
    "expiryDate": {
      "type": "string",
      "format": "date"
    }
  },
  "type": "object"
}
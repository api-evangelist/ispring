    "title",
    "type",
    "description",
    "addedDate",
    "viewUrl",
    "parentId",
    "isShared"
  ],
  "properties": {
    "contentItemId": {
      "type": "string",
      "format": "uuid"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "addedDate": {
      "type": "string",
      "format": "date-time"
    },
    "viewUrl": {
      "type": "string",
      "format": "url"
    },
    "parentId": {
      "type": "string",
      "format": "uuid"
    },
    "isShared": {
      "type": "boolean"
    }
  },
  "type": "object",
  "xml": {
    "name": "contentItem"
  }
}